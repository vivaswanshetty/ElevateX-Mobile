{
  "expo": {
    "name": "ElevateX",
    "slug": "elevatex",
    "scheme": "elevatex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#07080a",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07080a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vivaswan.shetty.elevatex"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07080a"
      },
      "package": "com.vivaswan.shetty.elevatex",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you set a profile picture and post images."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#07080a",
          "sounds": []
        }
      ],
      [
        "expo-updates",
        {
          "launchWaitMs": 2000
        }
      ]
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000,
      "url": "https://u.expo.dev/d10969e8-b2ca-45ea-9694-c933294201a6"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d10969e8-b2ca-45ea-9694-c933294201a6"
      }
    }
  }
}
